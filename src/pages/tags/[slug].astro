---
import SiteShell from '../../components/SiteShell.astro';
import PostList from '../../components/PostList.astro';
import { getTagBySlug, tags } from '../../data/blog';

export function getStaticPaths() {
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const tag = Astro.props.tag ?? getTagBySlug(Astro.params.slug ?? '');

if (!tag) {
  throw new Error(`Unknown tag: ${Astro.params.slug}`);
}
---

<SiteShell
  title={`${tag.name} | Tags | Duck-kyun Woo`}
  description={`Posts tagged with ${tag.name}`}
>
  <section class="archive-header">
    <p class="archive-eyebrow">Tag</p>
    <h1>#{tag.name}</h1>
    <p class="archive-description">
      같은 태그를 공유하는 글들을 모아볼 수 있는 페이지입니다.
    </p>
  </section>

  <PostList posts={tag.posts} />
</SiteShell>
