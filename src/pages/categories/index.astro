---
import SiteShell from '../../components/SiteShell.astro';
import { categories } from '../../data/blog';

const pageTitle = 'Categories | Duck-kyun Woo';
---

<SiteShell title={pageTitle} description="Browse posts by category">
  <section class="archive-header">
    <p class="archive-eyebrow">Categories</p>
    <h1>Category Archive</h1>
    <p class="archive-description">
      Browse posts grouped by topic for a quicker way to move through the archive.
    </p>
  </section>

  <div class="taxonomy-grid">
    {categories.map((category) => (
      <article class="taxonomy-card">
        <a href={category.url} class="taxonomy-link">
          <h2>{category.name}</h2>
          <p>{category.count} post{category.count === 1 ? '' : 's'}</p>
        </a>
      </article>
    ))}
  </div>
</SiteShell>
