---
import SiteShell from '../../components/SiteShell.astro';
import PostList from '../../components/PostList.astro';
import { categories, getCategoryBySlug } from '../../data/blog';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const category =
  Astro.props.category ?? getCategoryBySlug(Astro.params.slug ?? '');

if (!category) {
  throw new Error(`Unknown category: ${Astro.params.slug}`);
}
---

<SiteShell
  title={`${category.name} | Categories | Duck-kyun Woo`}
  description={`Posts filed under ${category.name}`}
>
  <section class="archive-header">
    <p class="archive-eyebrow">Category</p>
    <h1>{category.name}</h1>
    <p class="archive-description">Posts collected under this category.</p>
  </section>

  <PostList posts={category.posts} />
</SiteShell>
