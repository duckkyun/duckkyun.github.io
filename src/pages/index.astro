---
import SiteShell from '../components/SiteShell.astro';
import {
  aboutMeParagraphs,
  contactCards,
  education,
  experience,
  gpaSummary,
  highlights,
  languageScores,
  researchAreas,
  researchFocusSummary,
  researchThemes,
  strengths,
} from '../data/profile';

const [featuredExperience, ...otherExperience] = experience;

const githubCard = contactCards.find((item) => item.label === 'GitHub') ?? contactCards[0];
const blogCard = contactCards.find((item) => item.label === 'Personal blog') ?? contactCards[1];
const labCard = contactCards.find((item) => item.label === 'Lab homepage') ?? contactCards[2];

const connectionCards = [
  { ...githubCard, tone: 'cream' },
  { ...blogCard, tone: 'lavender' },
  { ...labCard, tone: 'mint' },
  {
    icon: 'record',
    label: 'Academic record',
    value: 'Current GPA transcript',
    href: gpaSummary.href,
    description: `Overall GPA ${gpaSummary.overall} / Major GPA ${gpaSummary.major}`,
    tone: 'sky',
  },
];

const boardColumns = [
  {
    title: 'Academic foundation',
    cards: [
      {
        tone: 'mint',
        badge: 'Foundation',
        title: `${education.institution} (${education.location})`,
        copy: education.degree,
      },
      {
        tone: 'sky',
        badge: 'Record',
        title: `GPA ${gpaSummary.overall}`,
        copy: `${gpaSummary.major} major / ${education.period}`,
        href: gpaSummary.href,
        action: 'Transcript',
      },
    ],
  },
  {
    title: 'Research queue',
    cards: researchAreas.slice(0, 3).map((area, index) => ({
      tone: ['peach', 'lavender', 'yellow'][index],
      badge: `0${index + 1}`,
      title: area,
      copy: researchThemes[index]?.description ?? researchFocusSummary,
    })),
  },
  {
    title: 'Live links',
    cards: [
      {
        tone: 'cream',
        badge: 'Code',
        title: githubCard.value,
        copy: githubCard.description,
        href: githubCard.href,
        action: 'Open',
      },
      {
        tone: 'rose',
        badge: 'Writing',
        title: blogCard.value,
        copy: blogCard.description,
        href: blogCard.href,
        action: 'Read',
      },
      {
        tone: 'mint',
        badge: 'Lab',
        title: labCard.value,
        copy: labCard.description,
        href: labCard.href,
        action: 'Visit',
      },
    ],
  },
];

const interestTones = ['peach', 'rose', 'mint', 'lavender'];
const experienceTones = ['peach', 'lavender', 'cream', 'mint', 'rose', 'sky'];
---

<SiteShell
  title="Duck-kyun Woo | Personal Website"
  description="A Notion-inspired personal website for Duck-kyun Woo, featuring academic foundation, research interests, and selected experience."
>
  <div class="page-stack">
    <section class="hero-band">
      <span class="hero-dot hero-dot--pink" aria-hidden="true"></span>
      <span class="hero-dot hero-dot--green" aria-hidden="true"></span>
      <span class="hero-dot hero-dot--yellow" aria-hidden="true"></span>
      <span class="hero-wire hero-wire--left" aria-hidden="true"></span>
      <span class="hero-wire hero-wire--right" aria-hidden="true"></span>

      <div class="hero-copy">
        <p class="hero-kicker">Personal website</p>
        <h1 class="hero-title">Preparing for the next shift in research.</h1>
        <p class="hero-subtitle">
          An interdisciplinary engineering undergraduate preparing for research-driven
          work across skin biology, immune responses, microbiome science, and
          translational biomedical study.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href={gpaSummary.href} target="_blank" rel="noreferrer">
            Open transcript
          </a>
          <a class="btn btn-secondary-dark" href={labCard.href} target="_blank" rel="noreferrer">
            Visit lab homepage
          </a>
        </div>
      </div>

      <article class="workspace-mockup-card">
        <div class="mockup-toolbar">
          <div class="mockup-dots" aria-hidden="true">
            <span class="mockup-dot"></span>
            <span class="mockup-dot"></span>
            <span class="mockup-dot"></span>
          </div>
          <p class="mockup-title">Duck-kyun research board</p>
          <span class="mockup-chip">Live overview</span>
        </div>

        <div class="mockup-grid">
          {boardColumns.map((column) => (
            <article class="mockup-column">
              <p class="mockup-column-title">{column.title}</p>
              <div class="mockup-column-stack">
                {column.cards.map((card) => (
                  <article class:list={['mockup-card', `mockup-card--${card.tone}`]}>
                    <span class="mockup-badge">{card.badge}</span>
                    <h3 class="mockup-card-title">{card.title}</h3>
                    <p class="mockup-card-copy">{card.copy}</p>
                    {card.href && (
                      <a
                        class="mockup-card-action"
                        href={card.href}
                        target="_blank"
                        rel="noreferrer"
                      >
                        {card.action}
                      </a>
                    )}
                  </article>
                ))}
              </div>
            </article>
          ))}
        </div>
      </article>
    </section>

    <section class="feature-section" id="overview">
      <div class="section-intro">
        <p class="section-kicker">Overview</p>
        <h2 class="section-title">Keep the next research move in one place.</h2>
        <p class="section-copy">
          The goal of this site is to turn CV fragments into a cleaner research-facing
          narrative, with enough structure to feel organized but enough personality to
          avoid looking like a plain resume export.
        </p>
      </div>

      <article class="feature-banner feature-banner--yellow">
        <div>
          <span class="banner-label">Highlights</span>
          <h3>
            College second-ranked entrant, department first-ranked entrant, and full
            scholarship recipient.
          </h3>
        </div>

        <ul class="banner-list">
          {highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>

      <div class="overview-grid">
        <article class="feature-card feature-card--cream feature-card--wide">
          <span class="card-eyebrow">About me</span>
          {aboutMeParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>

        <article class="feature-card feature-card--mint">
          <span class="card-eyebrow">Training</span>
          <h3>Interdisciplinary engineering as the starting point</h3>
          <p>{education.description}</p>
        </article>

        <article class="feature-card feature-card--peach">
          <span class="card-eyebrow">Preparation</span>
          <ul class="feature-list">
            {strengths.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="feature-card feature-card--sky">
          <span class="card-eyebrow">Signals</span>
          <div class="feature-metrics">
            <p class="feature-metric">
              <span>Language</span>
              {languageScores[0]}
            </p>
            <p class="feature-metric">
              <span>Advisor</span>
              Ji-Hwan Ryu
            </p>
          </div>
          <a class="text-link" href={gpaSummary.href} target="_blank" rel="noreferrer">
            Open current academic record
          </a>
        </article>
      </div>
    </section>

    <section class="feature-section" id="interests">
      <article class="feature-banner feature-banner--yellow feature-banner--split">
        <div>
          <p class="section-kicker section-kicker--dark">Research interests</p>
          <h2 class="section-title">Questions and systems I want to stay close to.</h2>
        </div>
        <p class="section-copy section-copy--dark">{researchFocusSummary}</p>
      </article>

      <div class="interest-grid">
        {researchAreas.map((area, index) => (
          <article class:list={['interest-tile', `interest-tile--${interestTones[index % interestTones.length]}`]}>
            <span class="interest-count">0{index + 1}</span>
            <h3>{area}</h3>
          </article>
        ))}
      </div>

      <div class="direction-grid">
        {researchThemes.map((item) => (
          <article class="direction-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="feature-section" id="experience">
      <div class="section-intro">
        <p class="section-kicker">Experience</p>
        <h2 class="section-title">Selected work across research, study, and teaching.</h2>
        <p class="section-copy">
          Internships, workshops, tutoring, and student leadership have all contributed
          to the kind of researcher and communicator I am trying to become.
        </p>
      </div>

      <div class="experience-layout">
        <article class="experience-feature">
          <span class="card-eyebrow">Most recent step</span>
          <span class="date-chip">{featuredExperience.date}</span>
          <h3>{featuredExperience.title}</h3>
          <p>{featuredExperience.description}</p>
        </article>

        <div class="experience-stack">
          {otherExperience.slice(0, 3).map((item, index) => (
            <article class:list={['feature-card', `feature-card--${experienceTones[index % experienceTones.length]}`]}>
              <span class="date-chip">{item.date}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="experience-grid">
        {otherExperience.slice(3).map((item, index) => (
          <article class="experience-card">
            <span class="date-chip">{item.date}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="experience-index">0{index + 4}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="feature-section">
      <div class="section-intro">
        <p class="section-kicker">Connections</p>
        <h2 class="section-title">Bring all your work together.</h2>
        <p class="section-copy">
          External destinations for code, writing, lab context, and the supporting
          academic record behind the numbers on this page.
        </p>
      </div>

      <div class="connection-grid">
        {connectionCards.map((item) => (
          <article class:list={['connection-card', `connection-card--${item.tone}`]}>
            <div class="connection-top">
              <span class:list={['connection-icon', `connection-icon--${item.icon}`]} aria-hidden="true">
                {item.icon === 'github' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path
                      fill="currentColor"
                      d="M12 0.5C5.65 0.5 0.5 5.65 0.5 12c0 5.08 3.29 9.4 7.86 10.92.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.67 1.25 3.32.95.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.17a10.9 10.9 0 0 1 5.78 0c2.2-1.48 3.17-1.17 3.17-1.17.63 1.59.24 2.76.12 3.05.74.8 1.18 1.82 1.18 3.07 0 4.41-2.69 5.39-5.26 5.67.41.36.78 1.08.78 2.18 0 1.58-.01 2.85-.01 3.24 0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35 0.5 12 0.5Z"
                    />
                  </svg>
                )}
                {item.icon === 'substack' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path
                      fill="currentColor"
                      d="M4 3.5h16v2.4H4zm0 4.2h16v2.3H4zm0 4.1h16v8.7l-8-5.2-8 5.2z"
                    />
                  </svg>
                )}
                {item.icon === 'beaker' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path
                      fill="currentColor"
                      d="M9 2.75a.75.75 0 0 0 0 1.5h.75v4.62l-4.2 6.53A3.5 3.5 0 0 0 8.5 20.75h7a3.5 3.5 0 0 0 2.95-5.35l-4.2-6.53V4.25H15a.75.75 0 0 0 0-1.5H9Zm2.25 1.5h1.5v4.84l1.15 1.79H9.1l1.15-1.79V4.25Zm-3.28 8.34h7.06l2.16 3.36a2 2 0 0 1-1.69 3.05h-7a2 2 0 0 1-1.68-3.05l2.15-3.36Zm1.43 1.66a.9.9 0 1 0 0 1.8.9.9 0 0 0 0-1.8Zm2.95.35a.65.65 0 1 0 0 1.3.65.65 0 0 0 0-1.3Zm2.2-.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z"
                    />
                  </svg>
                )}
                {item.icon === 'record' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path
                      fill="currentColor"
                      d="M6.5 3.5h8.6l3.4 3.4v11.6A2.5 2.5 0 0 1 16 21H6.5A2.5 2.5 0 0 1 4 18.5v-12A2.5 2.5 0 0 1 6.5 3.5Zm7.7 1.9v2.4h2.4L14.2 5.4ZM8 10.1h8v1.5H8Zm0 3.1h8v1.5H8Zm0 3.1h5.2v1.5H8Z"
                    />
                  </svg>
                )}
              </span>
              <span class="connection-label">{item.label}</span>
            </div>
            <a class="connection-link" href={item.href} target="_blank" rel="noreferrer">
              {item.value}
            </a>
            <p class="connection-copy">{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</SiteShell>
