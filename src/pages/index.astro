---
import PostList from '../components/PostList.astro';
import SiteShell from '../components/SiteShell.astro';
import { posts } from '../data/blog';
import {
  contactCards,
  education,
  experience,
  heroStats,
  highlights,
  languageScores,
  overviewParagraphs,
  researchAreas,
  researchThemes,
  strengths,
} from '../data/profile';

const recentPosts = posts.slice(0, 3);
---

<SiteShell
  title="Duck-kyun Woo | Responsive Personal Website"
  description="A responsive personal website for Duck-kyun Woo, built around academic background, research interests, and selected experience."
>
  <div class="home-stack">
    <section class="hero-section">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="archive-eyebrow">Curriculum vitae based website</p>
          <h1 class="display-title">Duck-kyun Woo</h1>
          <p class="hero-lead">
            An undergraduate at Konkuk University preparing for research-driven work in
            microbiome science, immune homeostasis, and translational biomedical study.
          </p>

          <div class="identity-row">
            <span class="identity-pill">B.S. Student</span>
            <span class="identity-pill">Konkuk University</span>
            <span class="identity-pill">Seoul, South Korea</span>
          </div>

          <div class="action-row">
            <a class="button-link primary" href="/#experience">View experience</a>
            <a class="button-link" href="/#research">Research interests</a>
            <a class="button-link subtle" href="/posts/">Writing archive</a>
          </div>
        </div>

        <aside class="hero-panel">
          <p class="panel-kicker">Quick Snapshot</p>
          <div class="metric-grid">
            {heroStats.map((item) => (
              <article class="metric-card">
                <span class="metric-label">{item.label}</span>
                <strong class="metric-value">{item.value}</strong>
              </article>
            ))}
          </div>

          <div class="divider" aria-hidden="true"></div>

          <div class="info-list">
            {contactCards.map((item) => (
              <article class="info-item">
                <span class="info-label">{item.label}</span>
                {item.href ? (
                  <a
                    class="info-link"
                    href={item.href}
                    target={item.href.startsWith('http') ? '_blank' : undefined}
                    rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                  >
                    {item.value}
                  </a>
                ) : (
                  <span class="info-value">{item.value}</span>
                )}
                <p class="info-copy">{item.description}</p>
              </article>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="section-card" id="overview">
      <div class="section-heading">
        <p class="archive-eyebrow">Overview</p>
        <h2>Building a path from interdisciplinary study to biomedical research</h2>
        <p class="section-lede">
          This homepage turns CV-style information into a cleaner personal narrative, with
          a layout that stays readable from wide screens down to phones.
        </p>
      </div>

      <div class="two-column-grid">
        <article class="surface-card prose-card">
          <h3>About me</h3>
          {overviewParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>

        <article class="surface-card">
          <h3>Highlights</h3>
          <ul class="feature-list">
            {highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section-card" id="research">
      <div class="section-heading">
        <p class="archive-eyebrow">Research Direction</p>
        <h2>Interests shaped by microbiome, immunity, and experimental systems</h2>
        <p class="section-lede">
          The current direction is to keep strengthening the bridge between foundational
          bioscience training and translational research questions.
        </p>
      </div>

      <div class="pill-cloud" aria-label="Research areas">
        {researchAreas.map((area) => (
          <span class="pill-tag">{area}</span>
        ))}
      </div>

      <div class="three-column-grid">
        {researchThemes.map((item) => (
          <article class="surface-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-card" id="education">
      <div class="section-heading">
        <p class="archive-eyebrow">Education</p>
        <h2>Academic foundation and supporting skills</h2>
      </div>

      <div class="two-column-grid">
        <article class="surface-card">
          <h3>{education.institution}</h3>
          <p class="card-accent">{education.degree}</p>
          <ul class="detail-list">
            <li>{education.period}</li>
            <li>{education.location}</li>
          </ul>
          <p>{education.description}</p>
        </article>

        <article class="surface-card">
          <h3>Strengths and credentials</h3>
          <ul class="feature-list">
            {strengths.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <div class="divider" aria-hidden="true"></div>

          <h3>Language scores</h3>
          <ul class="detail-list">
            {languageScores.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section-card" id="experience">
      <div class="section-heading">
        <p class="archive-eyebrow">Experience</p>
        <h2>Selected activities across research, study, and teaching</h2>
      </div>

      <div class="timeline">
        {experience.map((item) => (
          <article class="timeline-item">
            <span class="timeline-date">{item.date}</span>
            <div class="surface-card timeline-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-card" id="writing">
      <div class="section-header">
        <div class="section-heading compact">
          <p class="archive-eyebrow">Writing</p>
          <h2>Notes and posts</h2>
          <p class="section-lede">
            A small archive for reflections, technical notes, and updates published through
            this site.
          </p>
        </div>
        <a class="section-link" href="/posts/">See all posts</a>
      </div>

      <PostList posts={recentPosts} />
    </section>
  </div>
</SiteShell>
