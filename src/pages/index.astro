---
import SiteShell from '../components/SiteShell.astro';
import {
  aboutMeParagraphs,
  contactCards,
  education,
  earnedCreditsPdfUrl,
  experience,
  gpaSummary,
  highlights,
  languageScores,
  researchAreas,
  researchFocusSummary,
  researchThemes,
  strengths,
} from '../data/profile';
---

<SiteShell
  title="Duck-kyun Woo | Responsive Personal Website"
  description="A responsive personal website for Duck-kyun Woo, built around academic background, research interests, and selected experience."
>
  <div class="home-stack">
    <section class="hero-section">
      <div class="hero-stack-panel">
        <div class="hero-copy">
          <p class="section-eyebrow">Personal website</p>
          <h1 class="display-title">Duck-kyun Woo</h1>
          <p class="hero-lead">
            An undergraduate at Konkuk University preparing for research-driven work in
            microbiome science, immune homeostasis, and translational biomedical study.
          </p>
        </div>

        <div class="divider hero-divider" aria-hidden="true"></div>

        <section class="hero-panel">
          <div class="snapshot-academics">
            <article class="metric-card foundation-card">
              <span class="metric-label">Academic foundation</span>
              <strong class="foundation-title">
                {education.institution}
                <span class="foundation-location">({education.location})</span>
              </strong>
              <p class="foundation-degree">{education.degree}</p>
              <ul class="detail-list foundation-list">
                <li>{education.period}</li>
              </ul>
              <p class="gpa-inline-row">
                <span class="gpa-inline-label">GPA :</span>
                <a
                  class="metric-link gpa-inline-link"
                  href={gpaSummary.href}
                  target="_blank"
                  rel="noreferrer"
                >
                  {gpaSummary.overall} ({gpaSummary.major} Major)
                </a>
              </p>
            </article>
          </div>

          <div class="divider snapshot-divider" aria-hidden="true"></div>

          <div class="snapshot-links">
            {contactCards.map((item) => (
              <article class="info-item snapshot-link-card">
                <div class="info-label-row">
                  <span class:list={['contact-icon', `contact-icon--${item.icon}`]} aria-hidden="true">
                    {item.icon === 'github' && (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path
                          fill="currentColor"
                          d="M12 0.5C5.65 0.5 0.5 5.65 0.5 12c0 5.08 3.29 9.4 7.86 10.92.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.67 1.25 3.32.95.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.17a10.9 10.9 0 0 1 5.78 0c2.2-1.48 3.17-1.17 3.17-1.17.63 1.59.24 2.76.12 3.05.74.8 1.18 1.82 1.18 3.07 0 4.41-2.69 5.39-5.26 5.67.41.36.78 1.08.78 2.18 0 1.58-.01 2.85-.01 3.24 0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35 0.5 12 0.5Z"
                        />
                      </svg>
                    )}
                    {item.icon === 'substack' && (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path
                          fill="currentColor"
                          d="M4 3.5h16v2.4H4zm0 4.2h16v2.3H4zm0 4.1h16v8.7l-8-5.2-8 5.2z"
                        />
                      </svg>
                    )}
                    {item.icon === 'yonsei' && (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <circle cx="12" cy="12" r="10" fill="currentColor"></circle>
                        <path
                          fill="#ffffff"
                          d="M8.2 6.4h2.5l1.3 3.6 1.3-3.6h2.5l-3 6.5V17h-1.7v-4.1z"
                        />
                      </svg>
                    )}
                  </span>
                  <span class="info-label">{item.label}</span>
                </div>
                {item.href ? (
                  <a
                    class="info-link"
                    href={item.href}
                    target={item.href.startsWith('http') ? '_blank' : undefined}
                    rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                  >
                    {item.value}
                  </a>
                ) : (
                  <span class="info-value">{item.value}</span>
                )}
                <p class="info-copy">{item.description}</p>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>

    <section class="section-card" id="overview">
      <div class="section-heading">
        <p class="section-eyebrow">Overview</p>
        <h2>Building a path from interdisciplinary study to biomedical research</h2>
        <p class="section-lede">
          This homepage turns CV-style information into a cleaner personal narrative, with
          a layout that stays readable from wide screens down to phones.
        </p>
      </div>

      <div class="two-column-grid">
        <article class="surface-card prose-card">
          <h3>About me</h3>
          {aboutMeParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>

        <article class="surface-card">
          <h3>Highlights</h3>
          <ul class="feature-list">
            {highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section-card" id="research">
      <div class="section-heading">
        <p class="section-eyebrow">Research Direction</p>
        <h2>Research direction grounded in biology, systems, and translation</h2>
        <p class="section-lede">
          The current direction is to keep strengthening the bridge between foundational
          bioscience training and translational research questions.
        </p>
      </div>

      <div class="research-layout">
        <article class="surface-card research-summary-card">
          <h3>Current focus</h3>
          <p>{researchFocusSummary}</p>
          <ul class="detail-list">
            {researchAreas.map((area) => (
              <li>{area}</li>
            ))}
          </ul>
        </article>

        <div class="research-theme-list">
          {researchThemes.map((item) => (
            <article class="surface-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-card" id="education">
      <div class="section-heading">
        <p class="section-eyebrow">Education</p>
        <h2>Preparation and supporting skills</h2>
      </div>

      <div class="two-column-grid">
        <article class="surface-card">
          <h3>Current preparation</h3>
          <p class="card-accent">Interdisciplinary undergraduate training</p>
          <p>{education.description}</p>
          <ul class="feature-list">
            {strengths.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <div class="divider" aria-hidden="true"></div>

          <h3>Language scores</h3>
          <ul class="detail-list">
            {languageScores.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <div class="divider" aria-hidden="true"></div>

          <p class="document-note">
            GPA figures link to the current academic record PDF.
            <a href={earnedCreditsPdfUrl} target="_blank" rel="noreferrer">
              Open the document
            </a>
          </p>
        </article>
      </div>
    </section>

    <section class="section-card" id="experience">
      <div class="section-heading">
        <p class="section-eyebrow">Experience</p>
        <h2>Selected activities across research, study, and teaching</h2>
      </div>

      <div class="timeline">
        {experience.map((item) => (
          <article class="timeline-item">
            <span class="timeline-date">{item.date}</span>
            <div class="surface-card timeline-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</SiteShell>
