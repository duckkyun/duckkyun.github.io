---
import type { BlogPost } from '../data/blog';

interface Props {
  posts: BlogPost[];
  emptyText?: string;
}

const {
  posts,
  emptyText = '아직 등록된 글이 없습니다.',
} = Astro.props;
---

{
  posts.length > 0 ? (
    <div class="article-list">
      {posts.map((post) => (
        <article class="article-card">
          <header>
            <h3>
              <a href={post.url} class="silent-link">
                {post.title}
              </a>
            </h3>
          </header>
          <main>
            <p class="article-summary">{post.summary}</p>
          </main>
          <footer class="article-meta">
            <span class="meta-badge">{post.formattedDate}</span>
            {post.categories.map((category) => (
              <a href={category.url} class="meta-badge secondary">
                {category.name}
              </a>
            ))}
            {post.tags.map((tag) => (
              <a href={tag.url} class="tag-badge">
                #{tag.name}
              </a>
            ))}
          </footer>
        </article>
      ))}
    </div>
  ) : (
    <p class="empty-state">{emptyText}</p>
  )
}
