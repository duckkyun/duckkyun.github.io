---
import Layout from '../layouts/Layout.astro';
import { gpaSummary, siteNav } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Duck-kyun Woo',
  description = 'Responsive personal website of Duck-kyun Woo.',
} = Astro.props;

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (/^https?:\/\//.test(href)) {
    return false;
  }

  if (href.includes('#')) {
    return false;
  }

  const [target] = href.split('#');
  const resolvedTarget = target || '/';

  if (resolvedTarget === '/') {
    return pathname === '/';
  }

  return pathname === resolvedTarget || pathname.startsWith(resolvedTarget);
}
---

<Layout title={title} description={description}>
  <div class="site-bg">
    <header class="site-header">
      <div class="site-frame header-row">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">DW</span>
          <span class="brand-copy">
            <strong>Duck-kyun Woo</strong>
          </span>
        </a>

        <div class="nav-cluster">
          <nav class="site-nav" aria-label="Primary">
            {siteNav.map((item) => (
              <a
                class={`nav-link ${isActive(item.href) ? 'active' : ''}`}
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>

          <a class="header-cta" href={gpaSummary.href} target="_blank" rel="noreferrer">
            View transcript
          </a>
        </div>
      </div>
    </header>

    <main class="site-main">
      <div class="site-frame">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-frame footer-row">
        <p>Duck-kyun Woo</p>
        <p>Built with Astro and Pretendard for a research-oriented personal web presence.</p>
      </div>
    </footer>
  </div>
</Layout>
