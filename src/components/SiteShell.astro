---
import Layout from '../layouts/Layout.astro';
import { siteNav } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Duck-kyun Woo',
  description = 'Responsive personal website of Duck-kyun Woo.',
} = Astro.props;

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (/^https?:\/\//.test(href)) {
    return false;
  }

  const [target] = href.split('#');
  const resolvedTarget = target || '/';

  if (resolvedTarget === '/') {
    return pathname === '/';
  }

  return pathname === resolvedTarget || pathname.startsWith(resolvedTarget);
}
---

<Layout title={title} description={description}>
  <div class="site-bg">
    <header class="site-header">
      <div class="site-frame header-row">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">DW</span>
          <span class="brand-copy">
            <strong>Duck-kyun Woo</strong>
          </span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          {siteNav.map((item) => (
            <a
              class={`nav-link ${isActive(item.href) ? 'active' : ''}`}
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="site-frame">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-frame footer-row">
        <p>Duck-kyun Woo</p>
        <p>Built with Astro for a mobile-first personal web presence.</p>
      </div>
    </footer>
  </div>
</Layout>
